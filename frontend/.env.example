# API Endpoint Base
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Microsoft Authentication Library (MSAL) Configurations
NEXT_PUBLIC_MSAL_CLIENT_ID=your-azure-app-client-id
NEXT_PUBLIC_MSAL_AUTHORITY=https://login.microsoftonline.com/your-azure-tenant-id

# Enable or disable mock services (Mock Service Worker) for local UI/UX preview
NEXT_PUBLIC_ENABLE_MOCKS=true
