# ==============================================================================
# CareerHubV2 Environment Variables Template
# Copy this file to '.env' in both /backend and /frontend folders
# and fill in the real values.
# ==============================================================================

# --- Microsoft Entra ID (Shared) ---
# Found in Azure Portal > App Registrations > [Your App]
AZURE_TENANT_ID=your_tenant_id_here
AZURE_CLIENT_ID=your_client_id_here

# --- Backend Configuration (Go) ---
# Microsoft SQL Server connection string
# Example: sqlserver://username:password@localhost:1433?database=CareerHubDB
DB_CONNECTION_STRING=your_sql_connection_string_here
PORT=8080

# --- Frontend Configuration (React/Vite) ---
# Note: Vite variables MUST start with VITE_ to be accessible in the browser
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_AZURE_TENANT_ID=your_tenant_id_here
VITE_AZURE_CLIENT_ID=your_client_id_here
VITE_REDIRECT_URI=http://localhost:5173
